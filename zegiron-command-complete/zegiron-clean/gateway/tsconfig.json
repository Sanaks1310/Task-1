{
  "compilerOptions": {
    "noImplicitAny": false,
    "target":           "ES2022",
    "module":           "Node16",
    "moduleResolution": "Node16",
    "lib":              ["ES2022"],
    "outDir":           "dist",
    "rootDir":          "src",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "declaration":      true,
    "sourceMap":        true,
    "noUnusedLocals":false,
    "noUnusedParameters":false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
